# Required for drafting (skip with --no-llm)
OPENROUTER_API_KEY=

# Optional: OpenRouter model override (default: anthropic/claude-sonnet-4.5)
#OPENROUTER_MODEL=

# Required for `prospector source` (company discovery — no fallback).
# Optional for `run`: website/city resolution (degrades to DuckDuckGo search)
#GOOGLE_PLACES_API_KEY=

# Optional: Hunter.io email-name enrichment (skipped when absent)
#HUNTER_API_KEY=

# --- Approved-send (features 003/004) ---
# Provider: gmail (Gmail API, default) or smtp (authenticated SMTP, e.g. Zoho).
#PROSPECTOR_SEND_PROVIDER=smtp

# The dedicated outreach mailbox the tool sends from. REQUIRED for `send`;
# NEVER a personal account. For smtp it must equal PROSPECTOR_SMTP_USERNAME.
#PROSPECTOR_SEND_FROM=anas@omniveer.com
# Optional From display name -> "Anas from Omniveer <anas@omniveer.com>".
#PROSPECTOR_SEND_NAME=Anas from Omniveer
# Optional Reply-To header.
#PROSPECTOR_REPLY_TO=anas@omniveer.com

# --- SMTP transport (required when PROSPECTOR_SEND_PROVIDER=smtp) ---
#PROSPECTOR_SMTP_HOST=smtp.zoho.com
# ssl = implicit TLS (default, port 465); starttls = upgrade (port 587).
#PROSPECTOR_SMTP_SECURITY=ssl
# Optional; defaults to 465 (ssl) or 587 (starttls).
#PROSPECTOR_SMTP_PORT=465
#PROSPECTOR_SMTP_USERNAME=anas@omniveer.com
# Zoho app-specific password. Lives ONLY here (gitignored) — never logged,
# never committed. Leave this file's value empty.
#PROSPECTOR_SMTP_PASSWORD=

# Ramped daily cap: comma-separated weekly steps; the last value applies to week 4+.
#PROSPECTOR_SEND_CAPS=15,30,60,100
# Randomized delay (seconds) between real sends: "min,max".
#PROSPECTOR_SEND_DELAY=30,90
# Append-only send ledger path (gitignored). Default: send_ledger.jsonl
#PROSPECTOR_LEDGER=send_ledger.jsonl
# Gmail provider only: OAuth client secret + stored token (secrets/, gitignored).
#PROSPECTOR_GMAIL_CLIENT=secrets/gmail_client_secret.json
#PROSPECTOR_GMAIL_TOKEN=secrets/gmail_token.json
