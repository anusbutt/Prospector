# Required for drafting (skip with --no-llm)
OPENROUTER_API_KEY=

# Optional: OpenRouter model override (default: anthropic/claude-sonnet-4.5)
#OPENROUTER_MODEL=

# Required for `prospector source` (company discovery — no fallback).
# Optional for `run`: website/city resolution (degrades to DuckDuckGo search)
#GOOGLE_PLACES_API_KEY=

# Optional: Hunter.io email-name enrichment (skipped when absent)
#HUNTER_API_KEY=

# --- Approved-send (feature 003) ---
# The dedicated Nestaro outreach account the tool sends from. NEVER a personal account.
#PROSPECTOR_SEND_FROM=nestaroassistant@gmail.com
# Ramped daily cap: comma-separated weekly steps; the last value applies to week 4+.
#PROSPECTOR_SEND_CAPS=15,30,60,100
# Randomized delay (seconds) between real sends: "min,max".
#PROSPECTOR_SEND_DELAY=30,90
# Append-only send ledger path (gitignored). Default: send_ledger.jsonl
#PROSPECTOR_LEDGER=send_ledger.jsonl
# OAuth client secret + stored token (both under secrets/, gitignored).
#PROSPECTOR_GMAIL_CLIENT=secrets/gmail_client_secret.json
#PROSPECTOR_GMAIL_TOKEN=secrets/gmail_token.json
